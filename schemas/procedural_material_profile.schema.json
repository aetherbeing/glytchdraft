{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "glytchos.procedural_material_profile.v1",
  "title": "GlytchOS procedural material profile collection",
  "type": "object",
  "required": [
    "schema_version",
    "profiles"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "glytchos.procedural_material_profile.v1"},
    "profiles": {
      "type": "array",
      "items": {"$ref": "#/definitions/profile"}
    }
  },
  "definitions": {
    "profile": {
      "type": "object",
      "required": [
        "schema_version",
        "building_id",
        "evidence_provenance",
        "exterior_envelope",
        "roof",
        "glazing_character",
        "safeguards"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_version": {"const": "glytchos.procedural_material_profile.v1"},
        "building_id": {"type": "string", "minLength": 1},
        "evidence_provenance": {
          "type": "array",
          "items": {"$ref": "#/definitions/evidenceProvenance"},
          "uniqueItems": true
        },
        "exterior_envelope": {"$ref": "#/definitions/envelopeSurface"},
        "roof": {"$ref": "#/definitions/roofSurface"},
        "glazing_character": {"$ref": "#/definitions/glazingSurface"},
        "safeguards": {
          "type": "object",
          "required": ["visual_interpretation_only", "surveyed_truth"],
          "additionalProperties": false,
          "properties": {
            "visual_interpretation_only": {"const": true},
            "surveyed_truth": {"const": false}
          }
        }
      }
    },
    "evidenceProvenance": {
      "type": "object",
      "required": [
        "evidence_id",
        "source_type",
        "source_reference",
        "license",
        "confidence",
        "provenance_status",
        "quality_flags"
      ],
      "additionalProperties": false,
      "properties": {
        "evidence_id": {"type": "string", "minLength": 1},
        "source_type": {
          "enum": [
            "lidar",
            "aerial_imagery",
            "municipal_record",
            "zoning",
            "building_inventory",
            "street_scan",
            "user_contribution",
            "derived_geometry"
          ]
        },
        "source_reference": {"type": "string", "minLength": 1},
        "license": {"type": "string", "minLength": 1},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "provenance_status": {
          "enum": ["observed", "record_derived", "inferred", "unknown"]
        },
        "quality_flags": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    },
    "renderingParameters": {
      "type": "object",
      "required": [
        "base_color_range",
        "roughness_range",
        "metallic_range",
        "normal_intensity",
        "pattern_scale",
        "weathering_amount",
        "stain_amount",
        "reflectivity",
        "transparency",
        "variation_seed"
      ],
      "additionalProperties": false,
      "properties": {
        "base_color_range": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {"type": "number", "minimum": 0, "maximum": 1},
            "minItems": 3,
            "maxItems": 3
          },
          "minItems": 2,
          "maxItems": 2
        },
        "roughness_range": {
          "type": "array",
          "items": {"type": "number", "minimum": 0, "maximum": 1},
          "minItems": 2,
          "maxItems": 2
        },
        "metallic_range": {
          "type": "array",
          "items": {"type": "number", "minimum": 0, "maximum": 1},
          "minItems": 2,
          "maxItems": 2
        },
        "normal_intensity": {"type": "number", "minimum": 0, "maximum": 1},
        "pattern_scale": {"type": "number", "exclusiveMinimum": 0},
        "weathering_amount": {"type": "number", "minimum": 0, "maximum": 1},
        "stain_amount": {"type": "number", "minimum": 0, "maximum": 1},
        "reflectivity": {"type": "number", "minimum": 0, "maximum": 1},
        "transparency": {"type": "number", "minimum": 0, "maximum": 1},
        "variation_seed": {"type": "integer", "minimum": 0, "maximum": 4294967295}
      }
    },
    "candidateBase": {
      "type": "object",
      "required": [
        "material_class",
        "confidence",
        "evidence_references",
        "alternatives",
        "provenance_status",
        "uncertainty_notes"
      ],
      "additionalProperties": false,
      "properties": {
        "material_class": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "evidence_references": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "alternatives": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "provenance_status": {
          "enum": ["observed", "record_derived", "inferred", "unknown"]
        },
        "uncertainty_notes": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "envelopeCandidate": {
      "allOf": [
        {"$ref": "#/definitions/candidateBase"},
        {
          "properties": {
            "material_class": {
              "enum": [
                "stucco",
                "painted_concrete",
                "exposed_concrete",
                "brick",
                "stone",
                "metal_panel",
                "glass_curtain_wall",
                "wood",
                "generic_masonry",
                "unknown"
              ]
            }
          }
        }
      ]
    },
    "roofCandidate": {
      "allOf": [
        {"$ref": "#/definitions/candidateBase"},
        {
          "properties": {
            "material_class": {
              "enum": [
                "membrane",
                "gravel",
                "tile",
                "standing_seam_metal",
                "shingle",
                "concrete",
                "green_roof",
                "unknown"
              ]
            }
          }
        }
      ]
    },
    "glazingCandidate": {
      "allOf": [
        {"$ref": "#/definitions/candidateBase"},
        {
          "properties": {
            "material_class": {
              "enum": ["low", "moderate", "high", "curtain_wall", "unknown"]
            }
          }
        }
      ]
    },
    "envelopeSurface": {
      "type": "object",
      "required": ["ranked_candidates", "rendering_parameters"],
      "additionalProperties": false,
      "properties": {
        "ranked_candidates": {
          "type": "array",
          "items": {"$ref": "#/definitions/envelopeCandidate"},
          "minItems": 1
        },
        "rendering_parameters": {"$ref": "#/definitions/renderingParameters"}
      }
    },
    "roofSurface": {
      "type": "object",
      "required": ["ranked_candidates", "rendering_parameters"],
      "additionalProperties": false,
      "properties": {
        "ranked_candidates": {
          "type": "array",
          "items": {"$ref": "#/definitions/roofCandidate"},
          "minItems": 1
        },
        "rendering_parameters": {"$ref": "#/definitions/renderingParameters"}
      }
    },
    "glazingSurface": {
      "type": "object",
      "required": ["ranked_candidates", "rendering_parameters"],
      "additionalProperties": false,
      "properties": {
        "ranked_candidates": {
          "type": "array",
          "items": {"$ref": "#/definitions/glazingCandidate"},
          "minItems": 1
        },
        "rendering_parameters": {"$ref": "#/definitions/renderingParameters"}
      }
    }
  }
}
