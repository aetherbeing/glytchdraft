{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "glytchos.material_clue.v1",
  "title": "GlytchOS material clue",
  "type": "object",
  "required": [
    "clue_id",
    "building_id",
    "surface_type",
    "observation_type",
    "value",
    "source_type",
    "source_reference",
    "license",
    "confidence",
    "provenance_status"
  ],
  "additionalProperties": false,
  "properties": {
    "clue_id": {"type": "string", "minLength": 1},
    "building_id": {"type": "string", "minLength": 1},
    "surface_type": {
      "enum": ["envelope", "roof", "glazing", "ground_contact"]
    },
    "observation_type": {"type": "string", "minLength": 1},
    "value": {
      "type": ["string", "number", "integer", "boolean", "object", "array", "null"]
    },
    "unit": {"type": ["string", "null"]},
    "source_type": {
      "enum": [
        "lidar",
        "aerial_imagery",
        "municipal_record",
        "zoning",
        "building_inventory",
        "street_scan",
        "user_contribution",
        "derived_geometry"
      ]
    },
    "source_reference": {"type": "string", "minLength": 1},
    "observed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "license": {"type": "string", "minLength": 1},
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "spatial_resolution": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["value", "unit"],
      "properties": {
        "value": {"type": "number", "exclusiveMinimum": 0},
        "unit": {"type": "string", "minLength": 1}
      }
    },
    "quality_flags": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "provenance_status": {
      "enum": ["observed", "record_derived", "inferred", "unknown"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "source_type": {
            "enum": ["municipal_record", "zoning", "building_inventory"]
          }
        },
        "required": ["source_type"]
      },
      "then": {
        "properties": {
          "provenance_status": {
            "enum": ["record_derived", "inferred", "unknown"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {"source_type": {"const": "derived_geometry"}},
        "required": ["source_type"]
      },
      "then": {
        "properties": {
          "provenance_status": {"enum": ["inferred", "unknown"]}
        }
      }
    }
  ]
}
